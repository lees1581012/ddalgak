# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
REPLICATE_API_TOKEN=your_replicate_token_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ComfyUI Settings
# 3090 PC (로컬에서 실행 시)
# COMFYUI_BASE_URL=http://localhost:8000

# 외부 노트북 (VPN 접속 시 - 3090 PC IP)
# COMFYUI_BASE_URL=http://192.168.200.109:8000

# Output Directory
# 프로젝트 루트의 output 폴더 (기본값)
# OUTPUT_DIR=

# NAS 경로 (예: 네트워크 드라이브)
# OUTPUT_DIR=Z:\ddalgak\output
# OUTPUT_DIR=\\NAS\ddalgak\output

# 로컬 경로
# OUTPUT_DIR=C:\ddalgak_output

# Server Settings
PORT=9000
